{
  "name": "dictate",
  "version": "1.0.0",
  "description": "AI-powered voice dictation app for macOS",
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "wait-on http://localhost:5173 && npm run build:main && npm run build:preload && electron .",
    "build": "npm run build:main && npm run build:preload && vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "start": "electron .",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "dist:mac": "npm run build && electron-builder --mac --universal"
  },
  "author": "Dictate Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MasatoshiToku/dictate"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/react": "^14.1.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^40.6.1",
    "electron-builder": "^24.9.1",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.32",
    "prettier": "^3.2.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^7.0.0",
    "vite": "^5.0.10",
    "vitest": "^1.2.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.7.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^13.0.0",
    "zustand": "^4.4.7"
  },
  "build": {
    "appId": "io.dictate.app",
    "productName": "Dictate",
    "publish": {
      "provider": "github",
      "owner": "MasatoshiToku",
      "repo": "dictate"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "resources/icon.icns",
      "identity": "Apple Development: m.toku.mobile@gmail.com (U8WM579A3T)",
      "signIgnore": ["\\.pak$"],
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "hardenedRuntime": false,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "This app requires microphone access for voice dictation.",
        "NSAppleEventsUsageDescription": "This app requires accessibility access to type text into other applications."
      }
    },
    "files": [
      "dist/**/*",
      "resources/**/*"
    ],
    "directories": {
      "output": "release"
    }
  }
}
